CDK_DEFAULT_ACCOUNT=123456789012
CDK_DEFAULT_REGION=us-east-1
CDK_VPC_ID=vpc-1234567890abcdef0
CDK_PUBLIC_SUBNET_IDS=subnet-11111111,subnet-22222222
CDK_CERTIFICATE_ARN=arn:aws:acm:us-east-1:123456789012:certificate/00000000-0000-0000-0000-000000000000
CDK_BOOTSTRAP_USE_LOCAL_IMAGE=true
CDK_IMAGE_TAG=optional-when-CDK_BOOTSTRAP_USE_LOCAL_IMAGE-is-true
CDK_SECRET_KEY=replace-with-a-strong-random-secret
CDK_MONGO_URI=replace-with-mongodb-atlas-uri
