# Copy this file to .env and fill in the values, or run: make setup
# Docker Compose automatically loads .env when starting services.

# Required. Used for Flask session signing and CSRF token protection.
# Generate a value with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# MongoDB connection string (set automatically by docker-compose; override here for local use)
MONGO_URI=mongodb://localhost:27017/NOU_Enrollment
